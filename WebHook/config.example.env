# Archivo de configuración para variables de entorno
# Copia este archivo como .env y modifica los valores según necesites

# URL del webhook de destino
WEBHOOK_URL=https://webhook.site/tu-id-aqui

# Configuración por defecto del usuario
USUARIO=Tu Nombre Aquí

# Tecnología utilizada
TECNOLOGIA=FastAPI

# Mensaje por defecto para webhooks manuales
MENSAJE=Hola desde mi aplicación personalizada

# Mensaje por defecto para webhooks automáticos
MENSAJE_AUTO=Webhook automático personalizado

# Intervalo por defecto en segundos
INTERVALO_DEFAULT=5

# Mensaje de bienvenida
MENSAJE_BIENVENIDA=¡Bienvenido a mi API personalizada!

# Ejemplo de uso:
# Windows: set USUARIO=NuevoNombre && uvicorn server:app
# Linux/Mac: USUARIO=NuevoNombre uvicorn server:app
